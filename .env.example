# URL absoluta opcional del backend.
# En Railway apunta al backend publico, por ejemplo:
# VITE_API_URL=https://backend-benzanauto-production.up.railway.app
# Si la dejas vacía, el frontend usará /api en el mismo origen.
# Para generar sitemap dinámico con vehículos publicados durante el build,
# conviene definirla en producción.
VITE_API_URL=

# URL pública canónica del sitio.
# Mientras llega el dominio del cliente, usa aquí el dominio temporal del frontend
# que esté activo en Railway.
VITE_SITE_URL=

# Imagen social por defecto para Open Graph y Twitter.
# Puede ser relativa al frontend o absoluta.
VITE_DEFAULT_OG_IMAGE=/images/banner-desktop.webp

# Solo para desarrollo local con Vite proxy.
VITE_DEV_PROXY_TARGET=http://localhost:4000

# La configuracion del backend vive en backend/.env.example
