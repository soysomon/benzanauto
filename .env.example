# URL absoluta opcional del backend.
# En Railway apunta al backend publico, por ejemplo:
# VITE_API_URL=https://backend-benzanauto-production.up.railway.app
# Si la dejas vacía, el frontend usará /api en el mismo origen.
VITE_API_URL=

# Solo para desarrollo local con Vite proxy.
VITE_DEV_PROXY_TARGET=http://localhost:4000

# La configuracion del backend vive en backend/.env.example
