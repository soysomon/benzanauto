NODE_ENV=development
LOG_LEVEL=debug
LOG_SERVICE_NAME=benzan-auto-backend
# Solo local. En Railway no definas PORT manualmente.
PORT=4000
# Solo local. En produccion usa la URI real de MongoDB administrado.
MONGODB_URI=mongodb://127.0.0.1:27017/benzan
JWT_SECRET=reemplazar_con_un_secret_largo_de_al_menos_32_caracteres
JWT_EXPIRES_IN=12h

FRONTEND_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5173/admin
FRONTEND_URLS=https://benzanautoimport.com,https://www.benzanautoimport.com,http://localhost:5173,http://127.0.0.1:5173
# En Railway debe ser true.
TRUST_PROXY=false
ADMIN_AUTH_COOKIE_NAME=benzan_admin_session
ADMIN_AUTH_COOKIE_DOMAIN=
ADMIN_AUTH_COOKIE_PATH=/api/admin
ADMIN_AUTH_COOKIE_SAME_SITE=lax
# En produccion, si no la defines, el backend la resuelve como true.
ADMIN_AUTH_COOKIE_SECURE=
ADMIN_CSRF_HEADER_NAME=x-csrf-token
STORAGE_DRIVER=local

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
PUBLIC_CATALOG_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_CATALOG_RATE_LIMIT_MAX=600
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=900000
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=900000
RESET_PASSWORD_RATE_LIMIT_MAX=10
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
PASSWORD_MIN_LENGTH=12
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
PASSWORD_RESET_REQUEST_MIN_INTERVAL_MS=60000

JSON_BODY_LIMIT=1mb
URLENCODED_LIMIT=1mb
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_MAX_FILES=10
MAX_IMAGE_WIDTH=2400
MAX_IMAGE_HEIGHT=2400
SHARP_LIMIT_INPUT_PIXELS=50000000

# Para local, puede quedar vacio y se servira como /uploads/*
# Para S3/R2, usar el dominio publico o CDN del bucket.
UPLOADS_BASE_URL=
# Requeridas cuando STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

SUPERADMIN_NAME=Super Admin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=admin@benzan.local
SUPERADMIN_PASSWORD=cambiar_antes_de_produccion
SEED_DEMO_VEHICLES=false

EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_POOL=true
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_TLS_SERVERNAME=
SMTP_VERIFY_ON_STARTUP=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Benzan Auto Admin
EMAIL_REPLY_TO=

GEMINI_API_KEY=
GROQ_API_KEY=
AI_TIMEOUT_MS=12000
CHAT_INVENTORY_CACHE_MS=15000
USD_TO_DOP=60
