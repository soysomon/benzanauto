{
  "name": "benzan-auto-backend",
  "version": "1.0.0",
  "description": "Benzan Auto Import — Public + Admin Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/scripts/seed.js",
    "smoke": "node src/scripts/smoke-test.js",
    "email:verify": "node src/scripts/verify-email.js",
    "indexes:diff": "node src/scripts/sync-indexes.js",
    "indexes:sync": "node src/scripts/sync-indexes.js --apply",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run smoke && npm run audit:prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@google/genai": "^2.8.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "gcp-metadata": "^5.3.0",
    "groq-sdk": "^0.9.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "protobufjs": "^8.6.3",
    "qs": "^6.15.2",
    "ws": "^8.21.0"
  }
}
